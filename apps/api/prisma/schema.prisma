// schema.prisma
// ─────────────────────────────────────────────────────────────────────────────
// WHAT IS THIS FILE?
// This file describes your database in plain language.
// Prisma reads it and does two things:
//   1. Creates the actual tables in PostgreSQL (via "prisma migrate")
//   2. Generates TypeScript code you use to query the database (via "prisma generate")
//
// Think of it as a blueprint. The blueprint describes rooms.
// Prisma is the construction crew that builds them.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"

  // "native" = detect the current platform automatically.
  // On Debian slim (our Docker container), this resolves to
  // "debian-openssl-3.0.x" which works correctly.
  // On your local machine it resolves to whatever your OS needs.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  githubId  String   @unique
  username  String   @unique
  email     String
  avatarUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedWorkspaces  Workspace[]
  memberships      WorkspaceMember[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  members   WorkspaceMember[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  joinedAt    DateTime @default(now())
  role        Role     @default(member)

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

enum Role {
  owner
  admin
  member
  viewer
}