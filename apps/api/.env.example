# ─────────────────────────────────────────────────────────────────────────────
# DevFlow API — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=production

# Database — get from Neon (neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# GitHub OAuth App — get from github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Where your React app is deployed — e.g. https://devflow.vercel.app
CLIENT_URL=

# Redis — get from upstash.com
REDIS_URL=rediss://default:password@host:port

# GitHub webhook secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GITHUB_WEBHOOK_SECRET=

# GitHub Personal Access Token — get from github.com/settings/tokens
GITHUB_TOKEN=

# Groq AI — get from console.groq.com (free)
GROQ_API_KEY=